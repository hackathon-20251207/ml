S3_BUCKET=your-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
S3_ENDPOINT_URL= # optional, e.g. http://minio:9000

MODEL_KEY=S3D.onnx
CLASS_LIST_KEY=RSL_class_list.txt
MODEL_PATH=artifacts/S3D.onnx
CLASS_LIST_PATH=artifacts/RSL_class_list.txt

NUM_FRAMES=32
INPUT_SIZE=224

HOST=0.0.0.0
PORT=8085
RELOAD=false
USE_MOCK=false
FORCE_DOWNLOAD=false

# Optional artifact integrity checks (64 lowercase hex chars).
MODEL_SHA256=
CLASS_LIST_SHA256=

# Reject uncertain/ambiguous windows instead of returning an arbitrary argmax.
MIN_CONFIDENCE=0.5
MIN_MARGIN=0.1
TOP_K=3
NO_GESTURE_LABELS=no
NO_GESTURE_IDS=14

# Request and CPU/RAM safeguards.
MAX_FRAME_BYTES=524288
MAX_IMAGE_SIDE=2048
MAX_IMAGE_PIXELS=2000000
# Defaults to a value derived from NUM_FRAMES and MAX_FRAME_BYTES.
MAX_REQUEST_BYTES=22374016
INFERENCE_WAIT_SECONDS=0.25
ONNX_THREADS=2
